37889>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37892>>>        Case Begin
37892>>>            Case (NavigateData.eNavigateType = nfFromMain)
37894>>>                // If from main, this is a propbably a main file Select to Zoom.
37894>>>                Case Break
37895>>>
37895>>>            Case (NavigateData.eNavigateType = nfFromParent)
37898>>>                // If from parent, this is a constrained drill down.
37898>>>                Case Break
37899>>>
37899>>>            Case (NavigateData.eNavigateType = nfFromChild)
37902>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37902>>>                Case Break
37903>>>
37903>>>            Case Else // must be nfUndefined
37903>>>
37903>>>        Case End
37903>>>        
37903>>>        Send ShowInfoBox "2- Acabo de llegar" "Invoked View/ZoomEntrenador"
37904>>>
37904>>>        Send SetActionButtons
37905>>>        
37905>>>        If (HasRecord(Server(Self))) Begin
37907>>>        Send SetHeaderCaption  ("Entrenador:"*entrenador.Nombre)
37908>>>        Send SetBreadcrumbCaption entrenador.Nombre
37909>>>        End
37909>>>>
37909>>>        Else Begin
37910>>>            Send SetHeaderCaption  "Nuevo Entrenador"
37911>>>            Send SetBreadcrumbCaption "Nuevo"
37912>>>        End
37912>>>>
37912>>>    End_Procedure
