38576>>>                // If from parent, this is a constrained drill down.
38576>>>                Case Break
38577>>>
38577>>>            Case (NavigateData.eNavigateType = nfFromChild)
38580>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38580>>>                Case Break
38581>>>
38581>>>            Case Else // must be nfUndefined
38581>>>
38581>>>        Case End
38581>>>
38581>>>        Send SetActionButtons
38582>>>
38582>>>    End_Procedure
38583>>>
38583>>>End_Object 
