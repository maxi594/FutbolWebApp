37438>>>    Procedure DoLogin
37441>>>        String sLoginName sPassword sPrevStateHash
37441>>>        Boolean bResult
37441>>>        
37441>>>        WebGet psValue of oLoginName to sLoginName
37442>>>        WebGet psValue of oPassword to sPassword
37443>>>        
37443>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37444>>>        
37444>>>        If (bResult) Begin
37446>>>            Send Hide of oLogin
37447>>>            Send ShowHeader of ghoWebApp
37448>>>            WebSet psCSSClass of ghoWebApp to ""
37449>>>            
37449>>>            WebGet psPrevStateHash to sPrevStateHash
37450>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37451>>>            
37451>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37451>>>            WebSet psValue of oLoginName to ""
37452>>>            WebSet psValue of oPassword  to ""
37453>>>            WebSet pbVisible of oWarning to False
37454>>>        End
37454>>>>
37454>>>        Else Begin
37455>>>            WebSet pbVisible of oWarning to True
37456>>>        End
37456>>>>
37456>>>    End_Procedure
37457>>>    
37457>>>    Procedure OnSubmit
37460>>>        Send DoLogin
37461>>>    End_Procedure
37462>>>    
37462>>>    Procedure OnLoad
37465>>>        String sPrevStateHash sView
37465>>>        
37465>>>        Forward Send OnLoad
37467>>>        
37467>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37467>>>        Get StateHash of ghoWebApp to sPrevStateHash
37468>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37469>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37471>>>            WebSet psPrevStateHash to sPrevStateHash
37472>>>        End
37472>>>>
37472>>>        
37472>>>    End_Procedure
