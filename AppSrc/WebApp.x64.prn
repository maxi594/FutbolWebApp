37862>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37865>>>        Case Begin
37865>>>            Case (NavigateData.eNavigateType = nfFromMain)
37867>>>                // If from main, this is a propbably a main file Select to Zoom.
37867>>>                Case Break
37868>>>
37868>>>            Case (NavigateData.eNavigateType = nfFromParent)
37871>>>                // If from parent, this is a constrained drill down.
37871>>>                Case Break
37872>>>
37872>>>            Case (NavigateData.eNavigateType = nfFromChild)
37875>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37875>>>                Case Break
37876>>>
37876>>>            Case Else // must be nfUndefined
37876>>>
37876>>>        Case End
37876>>>        
37876>>>        Send ShowInfoBox "2- Acabo de llegar" "Invoked View/ZoomEntrenador"
37877>>>
37877>>>        Send SetActionButtons
37878>>>        
37878>>>        If (HasRecord(Server(Self))) Begin
37880>>>        Send SetHeaderCaption  ("Entrenador:"*entrenador.Nombre)
37881>>>        Send SetBreadcrumbCaption entrenador.Nombre
37882>>>        End
37882>>>>
37882>>>        Else Begin
37883>>>            Send SetHeaderCaption  "Nuevo Entrenador"
37884>>>            Send SetBreadcrumbCaption "Nuevo"
37885>>>        End
37885>>>>
37885>>>    End_Procedure
