38539>>>    Procedure SetActionButtons
38542>>>        tWebNavigateData NavigateData
38542>>>        tWebNavigateData NavigateData
38542>>>        Boolean bHasRecord
38542>>>        Handle hoDD
38542>>>
38542>>>        Get Server to hoDD
38543>>>        Get GetNavigateData to NavigateData
38544>>>        Get HasRecord of hoDD to bHasRecord
38545>>>
38545>>>        // let's hide all buttons and then Show the ones we want
38545>>>        WebSet pbRender of oEditBtn to False
38546>>>        WebSet pbRender of oSaveBtn to False
38547>>>        WebSet pbRender of oCancelChangesBtn to False
38548>>>        WebSet pbRender of oDeleteBtn to False
38549>>>
38549>>>        If (NavigateData.bReadOnly) Begin
38551>>>            WebSet pbRender of oEditBtn to True
38552>>>        End
38552>>>>
38552>>>        Else Begin
38553>>>            WebSet pbRender of oSaveBtn to True
38554>>>            WebSet pbRender of oCancelChangesBtn to True
38555>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38556>>>        End
38556>>>>
38556>>>    End_Procedure
38557>>>
38557>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38560>>>        // Close after save
38560>>>        Send NavigateClose Self
38561>>>    End_Procedure
38562>>>
38562>>>    // this will close the view after a delete
38562>>>    Procedure OnViewDeleted Handle hoDDO
38565>>>        Send NavigateClose Self
38566>>>    End_Procedure
