37856>>>                Case Break
37857>>>
37857>>>            Case (NavigateData.eNavigateType = nfFromParent)
37860>>>                // If from parent, this is a constrained drill down.
37860>>>                Case Break
37861>>>
37861>>>            Case (NavigateData.eNavigateType = nfFromChild)
37864>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37864>>>                Case Break
37865>>>
37865>>>            Case Else // must be nfUndefined
37865>>>
37865>>>        Case End
37865>>>
37865>>>        Send SetActionButtons
37866>>>
37866>>>    End_Procedure
