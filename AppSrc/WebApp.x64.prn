36734>>>>>>>        
36734>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36735>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36736>>>>>>>        Move (Free(pBase64)) to iLen
36737>>>>>>>        Function_Return ucaBuffer
36738>>>>>>>    End_Function
36739>>>>>>>    
36739>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36741>>>>>>>        Boolean bOk bRequireTimeCost
36741>>>>>>>        UChar[] ucaHash
36742>>>>>>>        
36742>>>>>>>        Case Begin
36742>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36744>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36745>>>>>>>                If (not(bOk)) Function_Return False
36748>>>>>>>                
36748>>>>>>>                Move True to bRequireTimeCost
36749>>>>>>>                Case Break
36750>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36753>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36754>>>>>>>                If (not(bOk)) Function_Return False
36757>>>>>>>                
36757>>>>>>>                Move True to bRequireTimeCost
36758>>>>>>>                Case Break
36759>>>>>>>            Case Else
36759>>>>>>>                Error 8710 "Invalid algorithm selected."
36760>>>>>>>>
36760>>>>>>>                Function_Return False
36761>>>>>>>        Case End
36761>>>>>>>        
36761>>>>>>>        String sSalt
36761>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36762>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36765>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36766>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36769>>>>>>>        
36769>>>>>>>        If (bRequireTimeCost) Begin
36771>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36772>>>>>>>        End
36772>>>>>>>>
36772>>>>>>>        Else Begin
36773>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36774>>>>>>>        End
36774>>>>>>>>
36774>>>>>>>        
36774>>>>>>>        Function_Return bOk
36775>>>>>>>    End_Function
36776>>>>>>>    
36776>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36778>>>>>>>        UChar[] ucaSalt
36779>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36780>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36783>>>>>>>        
36783>>>>>>>        If (num_arguments > 4) Begin
36785>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36786>>>>>>>        End
36786>>>>>>>>
36786>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36787>>>>>>>    End_Function
36788>>>>>>>    
36788>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36790>>>>>>>        Boolean bRequiresTimeCost
36790>>>>>>>        UInteger uiAlgo uiTimeCost
36790>>>>>>>        Integer iBegin iEnd
36790>>>>>>>        String sSalt
36790>>>>>>>        
36790>>>>>>>        Move 1 to iBegin
36791>>>>>>>        
36791>>>>>>>        // Parse Algo
36791>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36792>>>>>>>        If (not(iEnd)) Function_Return False
36795>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36796>>>>>>>        
36796>>>>>>>        // Parse Salt
36796>>>>>>>        Move (iEnd + 1) to iBegin
36797>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36798>>>>>>>        If (not(iEnd)) Function_Return False
36801>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36802>>>>>>>        
36802>>>>>>>        Case Begin
36802>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36804>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36807>>>>>>>                Move True to bRequiresTimeCost
36808>>>>>>>                Case Break
36809>>>>>>>            Case Else
36809>>>>>>>                Error 8710 "Invalid algorithm selected."
36810>>>>>>>>
36810>>>>>>>                Function_Return False
36811>>>>>>>        Case End
36811>>>>>>>        
36811>>>>>>>        // Parse optional timecost
36811>>>>>>>        If (bRequiresTimeCost) Begin
36813>>>>>>>            Move (iEnd + 1) to iBegin
36814>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36815>>>>>>>            If (not(iEnd)) Function_Return False
36818>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36819>>>>>>>        End
36819>>>>>>>>
36819>>>>>>>        
36819>>>>>>>        // Parse rest hash
36819>>>>>>>        Move (iEnd + 1) to iBegin
36820>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36821>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36824>>>>>>>        
36824>>>>>>>        // Base64Decode
36824>>>>>>>        UChar[] ucaSalt
36825>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36826>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36829>>>>>>>        
36829>>>>>>>        // Create new hash
36829>>>>>>>        String sNewHash
36829>>>>>>>        If (bRequiresTimeCost) Begin
36831>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36833>>>>>>>                Function_Return False 
36834>>>>>>>            End
36834>>>>>>>>
36834>>>>>>>        End
36834>>>>>>>>
36834>>>>>>>        Else Begin
36835>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36837>>>>>>>                Function_Return False 
36838>>>>>>>            End
36838>>>>>>>>
36838>>>>>>>        End
36838>>>>>>>>
36838>>>>>>>        Function_Return (sNewHash = sHash)
36839>>>>>>>    End_Function
36840>>>>>>>    
36840>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36842>>>>>>>        Boolean bRequireTimeCost
36842>>>>>>>        UBigInt ullSize
36842>>>>>>>        UChar[] ucaSalt
36843>>>>>>>        String sSalt
36843>>>>>>>        
36843>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36844>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36845>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36848>>>>>>>        
36848>>>>>>>        Case Begin
36848>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36850>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36851>>>>>>>                Move True to bRequireTimeCost
36852>>>>>>>                Case Break
36853>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36856>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36857>>>>>>>                Move True to bRequireTimeCost
36858>>>>>>>                Case Break
36859>>>>>>>            Case Else
36859>>>>>>>                Error 8710 "Invalid algorithm selected."
36860>>>>>>>>
36860>>>>>>>                Function_Return 0
36861>>>>>>>        Case End
36861>>>>>>>        
36861>>>>>>>        // calculate base64 in a non-floating-manner
36861>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36862>>>>>>>        
36862>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36863>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36864>>>>>>>        If (bRequireTimeCost) Begin
36866>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36867>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36868>>>>>>>        End
36868>>>>>>>>
36868>>>>>>>        Else Begin
36869>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36870>>>>>>>        End
36870>>>>>>>>
36870>>>>>>>        
36870>>>>>>>        Function_Return ullSize
36871>>>>>>>    End_Function
36872>>>>>>>End_Class
36873>>>>>>>
36873>>>>>>>Class cPasswordHasher is a cObject
36874>>>>>>>    
36874>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36875>>>>>>>    
36875>>>>>>>    Procedure Construct_Object
36877>>>>>>>        Forward Send Construct_Object
36879>>>>>>>        
36879>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36880>>>>>>>        Property UInteger   puiSaltSize         16
36881>>>>>>>        
36881>>>>>>>        Property UInteger   puiOptTimeCost      420000
36882>>>>>>>    End_Procedure
36883>>>>>>>    
36883>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36885>>>>>>>        Boolean bOk
36885>>>>>>>        UInteger uiAlgo
36885>>>>>>>        Get peAlgorithm to uiAlgo
36886>>>>>>>        
36886>>>>>>>        Case Begin
36886>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36888>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36891>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36892>>>>>>>                Case Break
36893>>>>>>>            Case Else
36893>>>>>>>                Error 8710 "Invalid algorithm selected."
36894>>>>>>>>
36894>>>>>>>                Function_Return False
36895>>>>>>>        Case End
36895>>>>>>>        
36895>>>>>>>        Function_Return bOk
36896>>>>>>>    End_Function
36897>>>>>>>    
36897>>>>>>>    Function RequiredBufferSize Returns UBigInt
36899>>>>>>>        UBigInt ullSize
36899>>>>>>>        UInteger uiAlgo
36899>>>>>>>        Get peAlgorithm to uiAlgo
36900>>>>>>>        
36900>>>>>>>        Case Begin
36900>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36902>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36905>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36906>>>>>>>                Case Break
36907>>>>>>>            Case Else
36907>>>>>>>                Error 8710 "Invalid algorithm selected."
36908>>>>>>>>
36908>>>>>>>                Function_Return 0
36909>>>>>>>        Case End
36909>>>>>>>        
36909>>>>>>>        Function_Return ullSize
36910>>>>>>>    End_Function
36911>>>>>>>
36911>>>>>>>End_Class
36912>>>>>
36912>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36913>>>>>    
36913>>>>>    Procedure Construct_Object
36915>>>>>        Handle hoObj
36915>>>>>        
36915>>>>>        Forward Send Construct_Object
36917>>>>>        
36917>>>>>        Set pbSessionCookieHttpOnly to True
36918>>>>>        
36918>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36919>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36920>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36921>>>>>        
36921>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36922>>>>>        Set phoUserDD to hoObj
36923>>>>>        
36923>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36924>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36925>>>>>        Set phoSessionDD to hoObj
36926>>>>>        
36926>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36927>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36928>>>>>        Set phoCrypto to hoObj
36929>>>>>        
36929>>>>>        Property Boolean pbPasswordHashing True
36930>>>>>        
36930>>>>>        Property Boolean pbCreatingNewSession False
36931>>>>>        Property String psLoginName
36932>>>>>        Property String psUserName ""
36933>>>>>        Property Integer piUserRights 0
36934>>>>>    End_Procedure
36935>>>>>    
36935>>>>>    Procedure End_Construct_Object
36937>>>>>        Forward Send End_Construct_Object
36939>>>>>        
36939>>>>>        Handle hoCrypto
36939>>>>>        Integer iFieldLen
36939>>>>>        If (pbPasswordHashing(Self)) Begin
36941>>>>>            Get phoCrypto to hoCrypto
36942>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36945>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36947>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36948>>>>>>
36948>>>>>            End
36948>>>>>>
36948>>>>>        End
36948>>>>>>
36948>>>>>    End_Procedure
36949>>>>>    
36949>>>>>    Function CreateSession String sRemoteAddress Returns String
36951>>>>>        String sSessionKey
36951>>>>>        Integer iErr
36951>>>>>        Boolean bLogWebSession
36951>>>>>        Handle hoSessionDD       
36951>>>>>        Get phoSessionDD to hoSessionDD
36952>>>>>        
36952>>>>>        //  Get session key
36952>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36954>>>>>        
36954>>>>>        Get pbLogWebSession to bLogWebSession
36955>>>>>        If not bLogWebSession Begin
36957>>>>>            Function_Return sSessionKey        
36958>>>>>        End
36958>>>>>>
36958>>>>>
36958>>>>>        //  Store session
36958>>>>>        Send Clear of hoSessionDD
36959>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36960>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36961>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36962>>>>>        Get Request_Validate of hoSessionDD to iErr
36963>>>>>        If (iErr) Begin
36965>>>>>            // this should not happen. If it does its a programming error
36965>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36966>>>>>>
36966>>>>>            Function_Return ""
36967>>>>>        End
36967>>>>>>
36967>>>>>        Send Request_Save of hoSessionDD
36968>>>>>        If (Err) Begin
36970>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36970>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36971>>>>>>
36971>>>>>            Function_Return ""
36972>>>>>        End
36972>>>>>>
36972>>>>>       
36972>>>>>        Function_Return sSessionKey        
36973>>>>>    End_Function
36974>>>>>    
36974>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36976>>>>>        DateTime dtLastAccess dtCurrent
36976>>>>>        TimeSpan tsDiff
36976>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36976>>>>>        Boolean bResult bCreatingNewSession
36976>>>>>        Boolean bLogWebSession bLoadWebApp
36976>>>>>        Integer eLoginMode
36976>>>>>        String sTime
36976>>>>>        Handle hoSessionDD hoUserDD       
36976>>>>>        
36976>>>>>        Move False to bLoadWebApp
36977>>>>>        If (num_arguments >= 2) Begin
36979>>>>>            Move bOptLoadWebApp to bLoadWebApp
36980>>>>>        End
36980>>>>>>
36980>>>>>        
36980>>>>>        Get phoSessionDD to hoSessionDD
36981>>>>>        Get phoUserDD to hoUserDD
36982>>>>>        
36982>>>>>        Get pbLogWebSession to bLogWebSession
36983>>>>>        Get peLoginMode to eLoginMode
36984>>>>>        
36984>>>>>        // for this object, you can only disable logging if login completely is disabled
36984>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36986>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36987>>>>>>
36987>>>>>            Function_Return False
36988>>>>>        End
36988>>>>>>
36988>>>>>
36988>>>>>        //  Clear session properties
36988>>>>>        Set psSessionKey to ""
36989>>>>>        Send UpdateSessionProperties True
36990>>>>>        
36990>>>>>        If not bLogWebSession Begin
36992>>>>>            Forward Get ValidateSession sSessionKey to bResult
36994>>>>>            Function_Return bResult
36995>>>>>        End        
36995>>>>>>
36995>>>>>        
36995>>>>>        Move False to bResult
36996>>>>>        Get piSessionTimeout to iSessionTimeout 
36997>>>>>        
36997>>>>>        //  Check if session exists
36997>>>>>        Send Clear of hoSessionDD
36998>>>>>        Move sSessionKey to WebAppSession.SessionKey
36999>>>>>        Send Find of hoSessionDD EQ Index.1
37000>>>>>            
37000>>>>>        If (Found) Begin
37002>>>>>            //  Calculate timespan between now and last access time
37002>>>>>            Move (CurrentDateTime()) to dtCurrent
37003>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37004>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37005>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37006>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37007>>>>>            
37007>>>>>            //  Check if session didn't time out
37007>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37009>>>>>                Forward Get ValidateSession sSessionKey to bResult
37011>>>>>                   
37011>>>>>                If (bResult) Begin
37013>>>>>                    //  Update session record
37013>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37014>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37015>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37016>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37017>>>>>                    Get Request_Validate of hoSessionDD to iErr
37018>>>>>                    If (iErr) Begin
37020>>>>>                        // this should not happen. If it does its a programming error
37020>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37021>>>>>>
37021>>>>>                        Function_Return False
37022>>>>>                    End
37022>>>>>>
37022>>>>>                    Send Request_Save of hoSessionDD
37023>>>>>                    
37023>>>>>                    //  Update user properties
37023>>>>>                    Send UpdateSessionProperties False
37024>>>>>                End
37024>>>>>>
37024>>>>>            End
37024>>>>>>
37024>>>>>            Else Begin
37025>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37025>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37026>>>>>                
37026>>>>>                If (not(bCreatingNewSession)) Begin
37028>>>>>                    If (not(bLoadWebApp)) Begin
37030>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37031>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37032>>>>>>
37032>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37033>>>>>                    End
37033>>>>>>
37033>>>>>                    Else Begin
37034>>>>>                        Set pbCreatingNewSession to True                    
37035>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37036>>>>>                        Set pbCreatingNewSession to False                        
37037>>>>>                    End
37037>>>>>>
37037>>>>>                End
37037>>>>>>
37037>>>>>            End
37037>>>>>>
37037>>>>>        End
37037>>>>>>
37037>>>>>        Else Begin
37038>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37039>>>>>>
37039>>>>>        End
37039>>>>>>
37039>>>>>        
37039>>>>>        Function_Return bResult
37040>>>>>    End_Function
37041>>>>>    
37041>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37043>>>>>        If (not(pbPasswordHashing(Self))) Begin
37045>>>>>            Move sPassword to sHash
37046>>>>>            Function_Return True
37047>>>>>        End
37047>>>>>>
37047>>>>>        
37047>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37049>>>>>            Function_Return False
37050>>>>>        End
37050>>>>>>
37050>>>>>        Move ("V1$" + sHash) to sHash
37051>>>>>        Function_Return True
37052>>>>>    End_Function
37053>>>>>    
37053>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37055>>>>>        If (not(pbPasswordHashing(Self))) Begin
37057>>>>>            Move False to bShouldUpgrade
37058>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37059>>>>>        End
37059>>>>>>
37059>>>>>        
37059>>>>>        String sVersion
37059>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37060>>>>>        If (sVersion = "V1$") Begin
37062>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37065>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37066>>>>>        End
37066>>>>>>
37066>>>>>        Else Begin
37067>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37070>>>>>            Function_Return False
37071>>>>>        End
37071>>>>>>
37071>>>>>    End_Function
37072>>>>>    
37072>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37074>>>>>        Handle hoUserDD
37074>>>>>        Integer iErr
37074>>>>>        Get phoUserDD to hoUserDD
37075>>>>>        
37075>>>>>        //  Find the user
37075>>>>>        Send Clear of hoUserDD
37076>>>>>        Move sLoginName to WebAppUser.LoginName
37077>>>>>        Send Find of hoUserDD EQ Index.1
37078>>>>>        If (Found) Begin
37080>>>>>            Send Clear of hoUserDD
37081>>>>>            Function_Return False
37082>>>>>        End
37082>>>>>>
37082>>>>>        
37082>>>>>        Send Clear of hoUserDD
37083>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37084>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37085>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37087>>>>>            Send Clear of hoUserDD
37088>>>>>            Function_Return False
37089>>>>>        End
37089>>>>>>
37089>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37090>>>>>        Get Request_Validate of hoUserDD to iErr
37091>>>>>        If (iErr) Begin
37093>>>>>            Send Clear of hoUserDD
37094>>>>>            Function_Return False
37095>>>>>        End
37095>>>>>>
37095>>>>>        
37095>>>>>        Send Request_Save of hoUserDD
37096>>>>>        Function_Return (not(Err))
37097>>>>>    End_Function
37098>>>>>    
37098>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37100>>>>>        String sSessionKey sUserPassword
37100>>>>>        Handle hoSessionDD hoUserDD
37100>>>>>        Boolean bMatch bUpgrade
37100>>>>>        
37100>>>>>        Get phoSessionDD to hoSessionDD
37101>>>>>        Get phoUserDD to hoUserDD
37102>>>>>        Integer iErr eLoginMode
37102>>>>>        
37102>>>>>        // Refind session record
37102>>>>>        Get psSessionKey to sSessionKey
37103>>>>>        Send Clear of hoSessionDD
37104>>>>>        Move sSessionKey to WebAppSession.SessionKey
37105>>>>>        Send Find of hoSessionDD EQ Index.1
37106>>>>>        
37106>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37108>>>>>            Get peLoginMode to eLoginMode
37109>>>>>            
37109>>>>>            //  Find the user
37109>>>>>            Move sLoginName to WebAppUser.LoginName
37110>>>>>            Send Find of hoUserDD EQ Index.1
37111>>>>>            
37111>>>>>            // Check username and password
37111>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37113>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37114>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37115>>>>>                
37115>>>>>                If (bMatch) Begin
37117>>>>>                    // Store the login
37117>>>>>                    If (bUpgrade) Begin
37119>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37120>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37123>>>>>                    End
37123>>>>>>
37123>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37124>>>>>                    Get Request_Validate of hoSessionDD to iErr
37125>>>>>                    If (iErr) Begin
37127>>>>>                        // this should not happen. If it does its a programming error
37127>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37128>>>>>>
37128>>>>>                        Function_Return False
37129>>>>>                    End
37129>>>>>>
37129>>>>>                    
37129>>>>>                    Send Request_Save of hoSessionDD
37130>>>>>                    
37130>>>>>                    // Update session properties
37130>>>>>                    Send UpdateSessionProperties False
37131>>>>>                    Send NotifyChangeRights
37132>>>>>                    Function_Return True
37133>>>>>                End
37133>>>>>>
37133>>>>>                Else Begin
37134>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37134>>>>>                    Send Clear of hoUserDD
37135>>>>>                End
37135>>>>>>
37135>>>>>            End
37135>>>>>>
37135>>>>>            Else Begin
37136>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37136>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37137>>>>>            End
37137>>>>>>
37137>>>>>        End
37137>>>>>>
37137>>>>>        Else Begin
37138>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37138>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37139>>>>>        End
37139>>>>>>
37139>>>>>          
37139>>>>>        Function_Return False
37140>>>>>    End_Function
37141>>>>>    
37141>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37143>>>>>        Handle hoUserDD
37143>>>>>        Integer iErr
37143>>>>>        Get phoUserDD to hoUserDD
37144>>>>>        
37144>>>>>        //  Find the user
37144>>>>>        Send Clear of hoUserDD
37145>>>>>        Move sLoginName to WebAppUser.LoginName
37146>>>>>        Send Find of hoUserDD EQ Index.1
37147>>>>>        If (not(Found)) Begin
37149>>>>>            Send Clear of hoUserDD
37150>>>>>            Function_Return False
37151>>>>>        End
37151>>>>>>
37151>>>>>        
37151>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37153>>>>>            Send Clear of hoUserDD
37154>>>>>            Function_Return False
37155>>>>>        End
37155>>>>>>
37155>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37156>>>>>        Get Request_Validate of hoUserDD to iErr
37157>>>>>        If (iErr) Begin
37159>>>>>            Send Clear of hoUserDD
37160>>>>>            Function_Return False
37161>>>>>        End
37161>>>>>>
37161>>>>>        
37161>>>>>        Send Request_Save of hoUserDD
37162>>>>>        Function_Return (not(Err))
37163>>>>>    End_Function
37164>>>>>    
37164>>>>>    Function IsLoggedIn Returns Boolean
37166>>>>>        String sLoginName
37166>>>>>        Boolean bLogWebSession bLoggedIn
37166>>>>>        
37166>>>>>        Get pbLogWebSession to bLogWebSession
37167>>>>>        If not bLogWebSession Begin
37169>>>>>            Forward Get IsLoggedIn to bLoggedIn
37171>>>>>            Function_Return bLoggedIn
37172>>>>>        End
37172>>>>>>
37172>>>>>        
37172>>>>>        Get psLoginName to sLoginName
37173>>>>>        
37173>>>>>        Function_Return (sLoginName <> "")
37174>>>>>    End_Function
37175>>>>>    
37175>>>>>    
37175>>>>>    //
37175>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37175>>>>>    // update properties based on the session and user data. Augment this function to update 
37175>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37175>>>>>    // the right records when this procedure is called.
37175>>>>>    //
37175>>>>>    // Params:
37175>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37175>>>>>    //
37175>>>>>    Procedure UpdateSessionProperties Boolean bClear
37177>>>>>        Handle hoUserDD
37177>>>>>        
37177>>>>>        Get phoUserDD to hoUserDD
37178>>>>>        
37178>>>>>        //  Update user properties
37178>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37180>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37181>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37182>>>>>            Set piUserRights to WebAppUser.Rights
37183>>>>>            
37183>>>>>            Send OnSessionPropertiesSet 
37184>>>>>        End
37184>>>>>>
37184>>>>>        Else Begin
37185>>>>>            Set psUsername to ""
37186>>>>>            Set psLoginName to ""
37187>>>>>            Set piUserRights to 0
37188>>>>>            
37188>>>>>            Send OnSessionPropertiesClear
37189>>>>>        End
37189>>>>>>
37189>>>>>    End_Procedure
37190>>>>>    
37190>>>>>    Procedure OnSessionPropertiesSet
37192>>>>>        //  Empty event stub
37192>>>>>    End_Procedure
37193>>>>>    
37193>>>>>    Procedure OnSessionPropertiesClear
37195>>>>>        //  Empty event stub
37195>>>>>    End_Procedure
37196>>>>>    
37196>>>>>    Procedure EndSession
37198>>>>>        Integer iErr
37198>>>>>        Boolean bLogWebSession
37198>>>>>        Handle hoSessionDD       
37198>>>>>        
37198>>>>>        Get phoSessionDD to hoSessionDD
37199>>>>>        Get pbLogWebSession to bLogWebSession
37200>>>>>        If not bLogWebSession Begin
37202>>>>>            Forward Send EndSession
37204>>>>>            Procedure_Return
37205>>>>>        End
37205>>>>>>
37205>>>>>            
37205>>>>>        //  Check if session exists
37205>>>>>        Send Clear of hoSessionDD
37206>>>>>        Get psSessionKey to WebAppSession.SessionKey
37207>>>>>        
37207>>>>>        Send Find of hoSessionDD EQ Index.1
37208>>>>>        If (Found) Begin
37210>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37211>>>>>            Get Request_Validate of hoSessionDD to iErr
37212>>>>>            If (iErr) Begin
37214>>>>>                // this should not happen. If it does its a programming error
37214>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37215>>>>>>
37215>>>>>                Procedure_Return
37216>>>>>            End
37216>>>>>>
37216>>>>>            Send Request_Save of hoSessionDD
37217>>>>>        End
37217>>>>>>
37217>>>>>    End_Procedure
37218>>>>>
37218>>>>>End_Class
