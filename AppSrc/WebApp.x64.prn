38547>>>    Procedure SetActionButtons
38550>>>        tWebNavigateData NavigateData
38550>>>        tWebNavigateData NavigateData
38550>>>        Boolean bHasRecord
38550>>>        Handle hoDD
38550>>>
38550>>>        Get Server to hoDD
38551>>>        Get GetNavigateData to NavigateData
38552>>>        Get HasRecord of hoDD to bHasRecord
38553>>>
38553>>>        // let's hide all buttons and then Show the ones we want
38553>>>        WebSet pbRender of oEditBtn to False
38554>>>        WebSet pbRender of oSaveBtn to False
38555>>>        WebSet pbRender of oCancelChangesBtn to False
38556>>>        WebSet pbRender of oDeleteBtn to False
38557>>>
38557>>>        If (NavigateData.bReadOnly) Begin
38559>>>            WebSet pbRender of oEditBtn to True
38560>>>        End
38560>>>>
38560>>>        Else Begin
38561>>>            WebSet pbRender of oSaveBtn to True
38562>>>            WebSet pbRender of oCancelChangesBtn to True
38563>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38564>>>        End
38564>>>>
38564>>>    End_Procedure
38565>>>
38565>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38568>>>        // Close after save
38568>>>        Send NavigateClose Self
38569>>>    End_Procedure
38570>>>
38570>>>    // this will close the view after a delete
38570>>>    Procedure OnViewDeleted Handle hoDDO
38573>>>        Send NavigateClose Self
38574>>>    End_Procedure
38575>>>
