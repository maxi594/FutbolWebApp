38578>>>        Case Begin
38578>>>            Case (NavigateData.eNavigateType = nfFromMain)
38580>>>                // If from main, this is a propbably a main file Select to Zoom.
38580>>>                Case Break
38581>>>
38581>>>            Case (NavigateData.eNavigateType = nfFromParent)
38584>>>                // If from parent, this is a constrained drill down.
38584>>>                Case Break
38585>>>
38585>>>            Case (NavigateData.eNavigateType = nfFromChild)
38588>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38588>>>                Case Break
38589>>>
38589>>>            Case Else // must be nfUndefined
38589>>>
38589>>>        Case End
38589>>>
38589>>>        Send SetActionButtons
38590>>>
38590>>>    End_Procedure
38591>>>
38591>>>End_Object 
