36598>>>>>>>    //
36598>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36598>>>>>>>    //
36598>>>>>>>    //  Params:
36598>>>>>>>    //      dtTime  Time to convert
36598>>>>>>>    //  Returns:
36598>>>>>>>    //      String with "HH:MM:SS" format
36598>>>>>>>    //
36598>>>>>>>    Function TimeToString DateTime dtTime Returns String
36600>>>>>>>        String sHours sMinutes sSeconds
36600>>>>>>>        
36600>>>>>>>        //  Extract parts
36600>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36601>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36602>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36603>>>>>>>        
36603>>>>>>>        //  Fill out with 0
36603>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36606>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36609>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36612>>>>>>>        
36612>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36613>>>>>>>    End_Function
36614>>>>>>>    
36614>>>>>>>    //
36614>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36614>>>>>>>    //
36614>>>>>>>    //  Params:
36614>>>>>>>    //      dtTime  Datetime variable to add time to
36614>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36614>>>>>>>    //  Returns:
