37834>>>    Procedure SetActionButtons
37837>>>        tWebNavigateData NavigateData
37837>>>        tWebNavigateData NavigateData
37837>>>        Boolean bHasRecord 
37837>>>        Handle hoDD
37837>>>
37837>>>        Get Server to hoDD
37838>>>        Get GetNavigateData to NavigateData
37839>>>        Get HasRecord of hoDD to bHasRecord
37840>>>
37840>>>        // let's hide all buttons and then Show the ones we want
37840>>>        WebSet pbRender of oEditBtn to False
37841>>>        WebSet pbRender of oSaveBtn to False
37842>>>        WebSet pbRender of oCancelChangesBtn to False
37843>>>        WebSet pbRender of oDeleteBtn to False
37844>>>
37844>>>        If (NavigateData.bReadOnly) Begin
37846>>>            WebSet pbRender of oEditBtn to True
37847>>>        End
37847>>>>
37847>>>        Else Begin
37848>>>            WebSet pbRender of oSaveBtn to True
37849>>>            WebSet pbRender of oCancelChangesBtn to True
37850>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37851>>>        End
37851>>>>
37851>>>    End_Procedure
37852>>>
