38727>>>            Case (NavigateData.eNavigateType = nfFromParent)
38730>>>                // If from parent, this is a constrained drill down.
38730>>>                Case Break
38731>>>
38731>>>            Case (NavigateData.eNavigateType = nfFromChild)
38734>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38734>>>                Case Break
38735>>>
38735>>>            Case Else // must be nfUndefined
38735>>>
38735>>>        Case End
38735>>>
38735>>>        Send SetActionButtons
38736>>>
38736>>>    End_Procedure
