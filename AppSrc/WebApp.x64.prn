37861>>>    Procedure SetActionButtons
37864>>>        tWebNavigateData NavigateData
37864>>>        tWebNavigateData NavigateData
37864>>>        Boolean bHasRecord 
37864>>>        Handle hoDD
37864>>>
37864>>>        Get Server to hoDD
37865>>>        Get GetNavigateData to NavigateData
37866>>>        Get HasRecord of hoDD to bHasRecord
37867>>>
37867>>>        // let's hide all buttons and then Show the ones we want
37867>>>        WebSet pbRender of oEditBtn to False
37868>>>        WebSet pbRender of oSaveBtn to False
37869>>>        WebSet pbRender of oCancelChangesBtn to False
37870>>>        WebSet pbRender of oDeleteBtn to False
37871>>>
37871>>>        If (NavigateData.bReadOnly) Begin
37873>>>            WebSet pbRender of oEditBtn to True
37874>>>        End
37874>>>>
37874>>>        Else Begin
37875>>>            WebSet pbRender of oSaveBtn to True
37876>>>            WebSet pbRender of oCancelChangesBtn to True
37877>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37878>>>        End
37878>>>>
37878>>>    End_Procedure
