37439>>>    Procedure DoLogin
37442>>>        String sLoginName sPassword sPrevStateHash
37442>>>        Boolean bResult
37442>>>        
37442>>>        WebGet psValue of oLoginName to sLoginName
37443>>>        WebGet psValue of oPassword to sPassword
37444>>>        
37444>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37445>>>        
37445>>>        If (bResult) Begin
37447>>>            Send Hide of oLogin
37448>>>            Send ShowHeader of ghoWebApp
37449>>>            WebSet psCSSClass of ghoWebApp to ""
37450>>>            
37450>>>            WebGet psPrevStateHash to sPrevStateHash
37451>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37452>>>            
37452>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37452>>>            WebSet psValue of oLoginName to ""
37453>>>            WebSet psValue of oPassword  to ""
37454>>>            WebSet pbVisible of oWarning to False
37455>>>        End
37455>>>>
37455>>>        Else Begin
37456>>>            WebSet pbVisible of oWarning to True
37457>>>        End
37457>>>>
37457>>>    End_Procedure
37458>>>    
37458>>>    Procedure OnSubmit
37461>>>        Send DoLogin
37462>>>    End_Procedure
37463>>>    
37463>>>    Procedure OnLoad
37466>>>        String sPrevStateHash sView
37466>>>        
37466>>>        Forward Send OnLoad
37468>>>        
37468>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37468>>>        Get StateHash of ghoWebApp to sPrevStateHash
37469>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37470>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37472>>>            WebSet psPrevStateHash to sPrevStateHash
37473>>>        End
37473>>>>
37473>>>        
37473>>>    End_Procedure
