38719>>>    Procedure SetActionButtons
38722>>>        tWebNavigateData NavigateData
38722>>>        tWebNavigateData NavigateData
38722>>>        Boolean bHasRecord
38722>>>        Handle hoDD
38722>>>
38722>>>        Get Server to hoDD
38723>>>        Get GetNavigateData to NavigateData
38724>>>        Get HasRecord of hoDD to bHasRecord
38725>>>
38725>>>        // let's hide all buttons and then Show the ones we want
38725>>>        WebSet pbRender of oEditBtn to False
38726>>>        WebSet pbRender of oSaveBtn to False
38727>>>        WebSet pbRender of oCancelChangesBtn to False
38728>>>        WebSet pbRender of oDeleteBtn to False
38729>>>
38729>>>        If (NavigateData.bReadOnly) Begin
38731>>>            WebSet pbRender of oEditBtn to True
38732>>>        End
38732>>>>
38732>>>        Else Begin
38733>>>            WebSet pbRender of oSaveBtn to True
38734>>>            WebSet pbRender of oCancelChangesBtn to True
38735>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38736>>>        End
38736>>>>
38736>>>    End_Procedure
