38693>>>    Procedure SetActionButtons
38696>>>        tWebNavigateData NavigateData
38696>>>        tWebNavigateData NavigateData
38696>>>        Boolean bHasRecord
38696>>>        Handle hoDD
38696>>>
38696>>>        Get Server to hoDD
38697>>>        Get GetNavigateData to NavigateData
38698>>>        Get HasRecord of hoDD to bHasRecord
38699>>>
38699>>>        // let's hide all buttons and then Show the ones we want
38699>>>        WebSet pbRender of oEditBtn to False
38700>>>        WebSet pbRender of oSaveBtn to False
38701>>>        WebSet pbRender of oCancelChangesBtn to False
38702>>>        WebSet pbRender of oDeleteBtn to False
38703>>>
38703>>>        If (NavigateData.bReadOnly) Begin
38705>>>            WebSet pbRender of oEditBtn to True
38706>>>        End
38706>>>>
38706>>>        Else Begin
38707>>>            WebSet pbRender of oSaveBtn to True
38708>>>            WebSet pbRender of oCancelChangesBtn to True
38709>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38710>>>        End
38710>>>>
38710>>>    End_Procedure
38711>>>
38711>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38714>>>        // Close after save
38714>>>        Send NavigateClose Self
38715>>>    End_Procedure
38716>>>
38716>>>    // this will close the view after a delete
38716>>>    Procedure OnViewDeleted Handle hoDDO
38719>>>        Send NavigateClose Self
38720>>>    End_Procedure
